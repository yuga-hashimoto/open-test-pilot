{
  "info": {
    "name": "Fixture API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "baseUrl", "value": "http://127.0.0.1:4174" }],
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" }
    },
    {
      "name": "Create user",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/users",
        "body": { "mode": "raw", "raw": "{\"email\":\"test@example.com\"}", "options": { "raw": { "language": "json" } } }
      }
    }
  ]
}
