{
  "name": "@open-test-pilot/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "bin": { "testpilot": "./dist/launcher.mjs" },
  "exports": { ".": "./src/index.ts" },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "lint": "tsc --noEmit --pretty false",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "build": "tsc --build && cp src/launcher.mjs dist/launcher.mjs"
  },
  "dependencies": {
    "@open-test-pilot/generator": "workspace:*",
    "@open-test-pilot/local-runner": "workspace:*",
    "@open-test-pilot/manifest-migrator": "workspace:*",
    "@open-test-pilot/playwright-adapter": "workspace:*",
    "@open-test-pilot/manifest-parser": "workspace:*",
    "@open-test-pilot/report": "workspace:*",
    "@open-test-pilot/result-schema": "workspace:*",
    "yaml": "^2.8.1",
    "tsx": "^4.23.1"
  }
}
