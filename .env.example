# Copy to .env.local for local team-mode experiments. Never commit real values.
PORT=3001
WEB_ORIGIN=http://127.0.0.1:4173
AUTH_REQUIRED=false
DATABASE_URL=postgres://opentestpilot:opentestpilot@127.0.0.1:5432/opentestpilot
REDIS_URL=redis://127.0.0.1:6379
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=opentestpilot
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me

# Required by the scheduler/runner when team mode is enabled.
OPENTESTPILOT_ORGANIZATION_ID=local-org
OPENTESTPILOT_ORGANIZATION_IDS=local-org
OPENTESTPILOT_URL=http://127.0.0.1:3001
OPENTESTPILOT_SESSION_TOKEN=
OPENTESTPILOT_WORKER_ENABLED=false
OPENTESTPILOT_REPAIR_WORKFLOW=false

# Optional GitHub App/OAuth integration.
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://127.0.0.1:3001/auth/github/callback
GITHUB_WEBHOOK_SECRET=
